{
  "name": "vscommander",
  "displayName": "VSCommander",
  "description": "Dual-panel file manager overlaid on a real terminal",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vscommander.open",
        "title": "VSCommander: Open Terminal"
      }
    ],
    "keybindings": [
      {
        "command": "vscommander.toggle",
        "key": "ctrl+o",
        "when": "terminalFocus"
      },
      {
        "command": "workbench.action.terminal.sendSequence",
        "args": { "text": "\u001b[1;3P" },
        "key": "alt+f1",
        "when": "terminalFocus && vscommander.panelVisible"
      },
      {
        "command": "workbench.action.terminal.sendSequence",
        "args": { "text": "\u001b[1;3Q" },
        "key": "alt+f2",
        "when": "terminalFocus && vscommander.panelVisible"
      },
      {
        "command": "workbench.action.terminal.sendSequence",
        "args": { "text": "\u001bOR" },
        "key": "f3",
        "when": "terminalFocus && vscommander.panelVisible"
      },
      {
        "command": "workbench.action.terminal.sendSequence",
        "args": { "text": "\u001b[1;5D" },
        "key": "ctrl+left",
        "when": "terminalFocus && vscommander.panelVisible"
      },
      {
        "command": "workbench.action.terminal.sendSequence",
        "args": { "text": "\u001b[1;5C" },
        "key": "ctrl+right",
        "when": "terminalFocus && vscommander.panelVisible"
      },
      {
        "command": "workbench.action.terminal.sendSequence",
        "args": { "text": "\u001b[19~" },
        "key": "f8",
        "when": "terminalFocus && vscommander.panelVisible"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vscommander",
          "title": "VSCommander",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "vscommander": [
        {
          "id": "vscommander.sidebar",
          "name": "VSCommander"
        }
      ]
    },
    "viewsWelcome": [],
    "configuration": {
      "title": "VSCommander",
      "properties": {
        "vscommander.showDotfiles": {
          "type": "boolean",
          "default": true,
          "description": "Show dotfiles (hidden files) in the panel"
        },
        "vscommander.clock": {
          "type": "boolean",
          "default": true,
          "description": "Show clock in the top-right corner of the panel"
        },
        "vscommander.panelColumns": {
          "type": "number",
          "default": 2,
          "minimum": 1,
          "maximum": 3,
          "description": "Number of file columns per panel (1, 2, or 3)"
        }
      }
    },
    "configurationDefaults": {
      "terminal.integrated.commandsToSkipShell": [
        "vscommander.toggle",
        "-workbench.action.terminal.findNext"
      ],
      "terminal.integrated.minimumContrastRatio": 1
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.3.0"
  }
}
